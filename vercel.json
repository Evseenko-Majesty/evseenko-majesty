{
  "rewrites": [
    {
      "source": "/apps/client",
      "destination": "/apps/client/index.html"
    },
    {
      "source": "/apps/client/:path*",
      "destination": "/apps/client/:path*"
    },

    {
      "source": "/apps/admin",
      "destination": "/apps/admin/index.html"
    },
    {
      "source": "/apps/admin/:path*",
      "destination": "/apps/admin/:path*"
    }
  ]
}