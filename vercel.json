{
  "builds": [
    {
      "src": "apps/**",
      "use": "@vercel/static"
    },
    {
      "src": "shared/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/shared/(.*)",
      "dest": "/shared/$1"
    },
    {
      "src": "/app_majesty/(.*)",
      "dest": "/apps/client/$1"
    },
    {
      "src": "/app_majesty",
      "dest": "/apps/client/index.html"
    },
    {
      "src": "/admin_majesty/(.*)",
      "dest": "/apps/admin/$1"
    },
    {
      "src": "/admin_majesty",
      "dest": "/apps/admin/index.html"
    }
  ]
}
